{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "lint": "npx eslint . --ext .ts --ext .vue --max-warnings 0 --fix --quiet 2>&1",
    "typecheck": "npx tsc -p tsconfig.app.json --noEmit && npx vue-tsc --noEmit"
  },
  "dependencies": {
    "@babylonjs/core": "^9.12.0",
    "vue": "^3.5.34"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/node": "^24.12.3",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.5.0",
    "eslint-plugin-vue": "^10.9.2",
    "jsdom": "^29.1.1",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.8",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.2.8"
  }
}
