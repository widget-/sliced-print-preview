# =============================================================================
# sliced-print-preview .gitignore
# =============================================================================

# --- OrcaSlicer build artifacts (optional — only if building from source) ---
OrcaSlicer/build/
OrcaSlicer/CMakeCache.txt
OrcaSlicer/CMakeFiles/
OrcaSlicer/deps/build/
OrcaSlicer/deps/DL_CACHE/

# --- Node / Bun ---
node_modules/
*.tsbuildinfo

# --- TypeScript compiled output ---
packages/backend/dist/
packages/frontend/dist/

# --- IDE / Editor ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# --- Environment (Nix) ---
.direnv/
result
result-*

# --- Test artifacts ---
coverage/
*.lcov

# --- OS files ---
Thumbs.db
Desktop.ini

# --- Temporary / generated ---
*.log
*.gcode
*.obj
*.mtl

*.png
result.json
/tmp/
/temp/

# --- Rust build artifacts ---
packages/gcode-to-segbin/target/

# --- Backup / scratch files ---
*.bak

# --- Bun lock files ---
bun.lock

# --- Local tooling ---
.reasonix/
!assets/preview.png
.envrc
reasonix.toml
